---
import { Image } from 'astro:assets'
import { getEntry, render } from 'astro:content'

import myImage from '../images/Stephanie_Rohr_Headshot.jpg'
import Layout from '../layouts/Layout.astro'

const contentEntry = await getEntry('pages', 'about')
if (!contentEntry) throw new Error('About page content not found')

const { Content } = await render(contentEntry)
---

<Layout title="About | Stephanie's Portfolio">
  <section class="section-wrapper">
    <div
      class="mt-8 grid grid-cols-1 items-start gap-8 lg:grid-cols-[1fr_440px] lg:gap-16"
    >
      <div
        class="order-2 max-w-full text-center lg:order-1 lg:max-w-[600px] lg:text-left"
      >
        <h1 class="page-title lg:text-left">
          <span class="gradient-heading">{contentEntry.data.pageHeading}</span>
        </h1>

        <div class="text-[1.05rem] leading-8 [&_p]:mb-6">
          <Content />
        </div>
      </div>

      <div class="relative order-1 mx-auto lg:order-2">
        <Image
          src={myImage}
          alt={contentEntry.data.imageAlt || "Stephanie Rohr headshot"}
          width="508"
          height="508"
          loading="eager"
          class="w-full max-w-[320px] rounded-lg object-cover shadow-[0_10px_40px_rgba(0,0,0,0.08)] sm:max-w-[400px] lg:h-[500px] lg:w-[440px] lg:max-w-none"
        />
      </div>
    </div>

    <hr class="divider-line" />
  </section>
</Layout>
