---
import { Image } from 'astro:assets'
import { getEntry, render } from 'astro:content'

import myImage from '../images/Stephanie_Rohr_Headshot.jpg'
import Layout from '../layouts/Layout.astro'

const contentEntry = await getEntry('pages', 'about')
if (!contentEntry) throw new Error('About page content not found')

const { Content } = await render(contentEntry)
---

<Layout title="About | Stephanie's Portfolio">
  <section class="section about-section">
    <div class="about-container">
      <div class="about-content">
        <h1 class="page-heading">
          <span class="highlight">{contentEntry.data.pageHeading}</span>
        </h1>

        <div class="bio">
          <Content />
        </div>
      </div>

      <div class="headshot-wrapper">
        <Image
          src={myImage}
          alt={contentEntry.data.imageAlt || "Stephanie Rohr headshot"}
          width="508"
          height="508"
          loading="eager"
        />
      </div>
    </div>

    <hr class="divider" />
  </section>
</Layout>

<style>
  .about-container {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 4rem;
    align-items: start;
    margin-top: 2rem;
  }

  .about-content {
    max-width: 600px;
  }

  .page-heading {
    text-align: left;
    margin-bottom: 2rem;
  }

  .headshot-wrapper {
    position: relative;
  }

  .headshot-wrapper img {
    width: 440px;
    height: 500px;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  }

  .bio {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .bio p {
    margin-bottom: 1.5rem;
  }

  @media (max-width: 968px) {
    .about-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-content {
      max-width: 100%;
    }

    .page-heading {
      text-align: center;
    }

    .headshot-wrapper {
      order: -1;
      margin: 0 auto;
    }

    .headshot-wrapper img {
      width: 100%;
      max-width: 400px;
      height: auto;
    }

    .bio {
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .headshot-wrapper img {
      max-width: 320px;
    }
  }
</style>
