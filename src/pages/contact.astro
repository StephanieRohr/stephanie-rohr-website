---
import { getCollection, getEntry } from 'astro:content'

import ContactForm from '../components/organisms/ContactForm'
import Layout from '../layouts/Layout.astro'

const contentEntry = await getEntry('pages', 'contact')
if (!contentEntry) throw new Error('Contact page content not found')

const contactFormEntry = await getEntry('contactForm', 'contactform')
if (!contactFormEntry) throw new Error('Contact form content not found')

const mainEntry = await getEntry('main', 'main')
if (!mainEntry) throw new Error('Site data not found')
---

<Layout title="Contact | Stephanie's Portfolio">
  <section class="section contact-section">
    <h1 class="page-heading">
      <span class="highlight">{contentEntry.data.pageHeading}</span>
    </h1>
    <h2 class="subheading">{contentEntry.data.subheading}</h2>

    <div class="contact-info">
      <p class="reach-label">{contentEntry.data.reachLabel}</p>
      <p>
        <a href={`mailto:${mainEntry.data.email}`}>{mainEntry.data.email}</a>
      </p>
      <p>
        <a href={`tel:${mainEntry.data.phone?.replace(/-/g, "")}`}
          >{mainEntry.data.phone}</a
        >
      </p>
    </div>

    <hr class="divider" />

    <ContactForm client:visible content={contactFormEntry.data} />
  </section>
</Layout>

<style>
  .contact-section {
    max-width: 600px;
  }

  .subheading {
    font-family: "Baskerville", "Georgia", serif;
    font-size: 1.4rem;
    font-weight: 400;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .contact-info {
    text-align: center;
    margin-bottom: 1rem;
  }

  .reach-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .contact-info a {
    color: var(--color-accent);
    font-size: 1.1rem;
  }

  .contact-info p {
    margin-bottom: 0.25rem;
  }
</style>

<style is:global>
  .contact-form {
    max-width: 500px;
    margin: 0 auto;
  }

  .form-intro {
    text-align: center;
    font-size: 1rem;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    margin-bottom: 1rem;
  }

  .form-field label {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
  }

  .required {
    color: var(--color-accent);
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-field textarea {
    resize: vertical;
  }

  .btn-submit {
    display: block;
    width: 100%;
    padding: 0.75rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: 4px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    background: var(--color-accent-hover);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-success {
    text-align: center;
    padding: 2rem;
    font-size: 1.2rem;
    color: var(--color-accent);
    font-family: var(--font-heading);
  }

  @media (max-width: 500px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
