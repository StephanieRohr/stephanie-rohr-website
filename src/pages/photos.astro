---
import { getEntry, render } from 'astro:content'

import ImageGallery from '../components/organisms/ImageGallery.astro'
import Layout from '../layouts/Layout.astro'

const contentEntry = await getEntry('pages', 'photos')
if (!contentEntry) throw new Error('Photos page content not found')

const { Content } = await render(contentEntry)
---

<Layout title="Photos | Stephanie's Portfolio">
  <section class="section photos-section">
    <h1 class="page-heading">
      <span class="highlight">{contentEntry.data.pageHeading}</span>
    </h1>

    <div class="photos-intro">
      <p>
        <Content />
      </p>
    </div>

    <ImageGallery directory="ActionSportsPhotography" />

    <hr class="divider" />

    <ImageGallery directory="EventPhotography" />

    <hr class="divider" />

    <ImageGallery directory="Graphics" />

    <hr class="divider" />

    <ImageGallery directory="HeadshotPhotos" />

    <hr class="divider" />

    <ImageGallery directory="ProductPhotos" />

    <hr class="divider" />

    <ImageGallery directory="ScenicNaturePhotos" />
  </section>
</Layout>

<style>
  .photos-intro {
    max-width: 800px;
    margin: 0 auto 2rem;
    font-size: 1rem;
    line-height: 1.8;
    text-align: center;
  }

  .gallery-embed {
    max-width: 800px;
    margin: 2rem auto;
    background: white;
    border: 1px solid var(--color-line);
    border-radius: 12px;
  }
</style>
