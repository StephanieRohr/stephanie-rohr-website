---
import { getEntry, render } from 'astro:content'
import Layout from '../layouts/Layout.astro'

const contentEntry = await getEntry('pages', 'photos')
if (!contentEntry) throw new Error('Photos page content not found')
const { Content } = await render(contentEntry)
---

<Layout title="Photos | Stephanie's Portfolio">
  <section class="section photos-section">
    <h1 class="page-heading">
      <span class="highlight">{contentEntry.data.pageHeading}</span>
    </h1>

    <div class="photos-intro">
      <p>
        <Content />
      </p>
    </div>

    <div class="gallery-embed">
      <iframe
        width="100%"
        height="400"
        title="Google Drive"
        aria-label="Google Drive"
        scrolling="no"
        allowfullscreen
        allowtransparency="true"
        allow="clipboard-write;autoplay;camera;microphone;geolocation;vr"
        style="border: none; overflow: hidden;"
        src="https://wixlabs-drive.appspot.com/widget?pageId=i0bc4&compId=comp-mbgl68yy&viewerCompId=comp-mbgl68yy&siteRevision=163&viewMode=site&deviceType=desktop&locale=en&tz=America%2FNew_York&regionalLanguage=en&width=895&height=870&instance=ObYjM4_8BSEOpapQ4KnX4BHcRUN7KXsn69n-dG7ybgk.&currency=USD&currentCurrency=USD&commonConfig=%7B%22brand%22%3A%22wix%22%2C%22host%22%3A%22VIEWER%22%2C%22bsi%22%3A%22df58229e-7c3b-4d06-9351-8ec2e5989b8d%7C1%22%2C%22siteRevision%22%3A%22163%22%2C%22renderingFlow%22%3A%22NONE%22%2C%22language%22%3A%22en%22%2C%22locale%22%3A%22en-us%22%2C%22BSI%22%3A%22df58229e-7c3b-4d06-9351-8ec2e5989b8d%7C1%22%7D&currentRoute=.%2Fphotography&vsi=a06d480f-3f0a-4ff0-8902-ff8c8992035b"
      ></iframe>
    </div>

    <hr class="divider" />
  </section>
</Layout>

<style>
  .photos-intro {
    max-width: 800px;
    margin: 0 auto 2rem;
    font-size: 1rem;
    line-height: 1.8;
    text-align: center;
  }

  .gallery-embed {
    max-width: 800px;
    margin: 2rem auto;
    background: white;
    border: 1px solid var(--color-line);
    border-radius: 12px;
  }
</style>
