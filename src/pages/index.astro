---
import { VideoPlayer } from '../components/atoms/VideoPlayer'
import Layout from '../layouts/Layout.astro'
---

<Layout title="Home | Stephanie's Portfolio">
  <section class="hero">
    <div class="hero-inner">
      <VideoPlayer
        type="youtube-hero"
        url="https://www.youtube.com/watch?v=TCCUvF59fPc"
        boxShadow="0 4px 30px rgba(0, 0, 0, 0.08)"
        client:visible
      />
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--nav-height));
    padding: 2rem 1.5rem;
    background: linear-gradient(
      180deg,
      var(--clr-trooper-a0) 0%,
      var(--clr-trooper-a10) 100%
    );
  }

  .hero-inner {
    max-width: 900px;
    width: 100%;
  }
</style>
