---
import { VideoPlayer } from '../components/atoms/VideoPlayer'
import Layout from '../layouts/Layout.astro'
---

<Layout title="Home | Stephanie's Portfolio">
  <section
    class="flex min-h-[calc(100dvh-var(--spacing-nav))] items-center justify-center px-6 py-8"
  >
    <div class="w-full max-w-225">
      <VideoPlayer
        url="https://www.youtube.com/watch?v=TCCUvF59fPc"
        boxShadow="0 4px 30px rgba(0, 0, 0, 0.08)"
        client:visible
      />
    </div>
  </section>
</Layout>
