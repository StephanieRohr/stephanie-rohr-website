---
interface Props {
  heading: string
  description: string
  credits: string
}

const { heading, description, credits } = Astro.props
---

<>
  <h2 class="font-heading mb-3 text-2xl font-bold text-accent">{heading}</h2>
  <p class="mb-2 max-w-200 text-[0.95rem] leading-7">{description}</p>
  <p class="mb-6 text-[0.85rem] leading-6 whitespace-pre-line text-muted">
    {credits}
  </p>
</>
