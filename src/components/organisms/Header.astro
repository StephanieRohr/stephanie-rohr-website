---
import { getEntry } from 'astro:content'
import { BrandLink } from '../atoms/BrandLink'
import { NavigationMenu } from '../molecules/NavigationMenu'
import { SocialLinks } from '../molecules/SocialLinks'

const mainEntry = await getEntry('main', 'main')
if (!mainEntry) throw new Error('Site content not found')
---

<header class="site-header">
  <div class="header-inner">
    <BrandLink client:load name={mainEntry.data.name} />
    <NavigationMenu
      client:load
      nav={mainEntry.data.nav}
      social={mainEntry.data.social}
    />
    <SocialLinks client:load links={mainEntry.data.social} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: none;
  }

  /* Bottom gradient rule */
  .site-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--clr-trooper-a20) 30%,
      var(--clr-trooper-a30) 70%,
      transparent
    );
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: var(--nav-height);
  }
</style>

<style is:global>
  /* Nav Toggle Button */
  .nav-toggle {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    background: transparent;
    border: none;
    color: inherit;
    text-align: center;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (min-width: 1024px) {
    .nav-toggle {
      display: none;
    }
  }

  .nav-toggle-icon {
    width: 1.5rem;
    height: 1.5rem;
    fill: currentColor;
    pointer-events: none;
  }

  .nav-toggle-bar {
    transform-origin: center;
    transition: all 300ms cubic-bezier(0.5, 0.85, 0.25, 1.1);
  }

  .nav-toggle-bar--top {
    transform: translate(0.4375rem, -0.3125rem);
  }

  .nav-toggle-bar--middle {
    transition-timing-function: cubic-bezier(0.5, 0.85, 0.25, 1.8);
  }

  .nav-toggle-bar--bottom {
    transform: translateY(0.3125rem);
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar--top {
    transform: rotate(315deg);
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar--middle {
    transform: rotate(45deg);
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar--bottom {
    transform: rotate(135deg);
  }
</style>
