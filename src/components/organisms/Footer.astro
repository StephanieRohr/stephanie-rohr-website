---
interface Props {
  name: string
}

const { name } = Astro.props
---

<footer class="relative hairline-top px-6 py-8 text-center">
  <div class="mx-auto max-w-site">
    <p class="text-[0.85rem] text-muted">
      &copy; {new Date().getFullYear()}
      {name}. All rights reserved.
    </p>
  </div>
</footer>
