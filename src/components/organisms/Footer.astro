---
interface Props {
  name: string
}

const { name } = Astro.props
---

<footer class="site-footer">
  <div class="footer-inner">
    <p>
      &copy; {new Date().getFullYear()}
      {name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    border-top: none;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  /* Top gradient rule */
  .site-footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--clr-trooper-a20) 30%,
      var(--clr-trooper-a30) 70%,
      transparent
    );
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-inner p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
